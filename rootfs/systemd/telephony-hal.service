[Unit]
Description=Ubuntu GSI Telephony HAL — Vendor Radio/Modem Bridge
Documentation=https://github.com/zerofrip/Ubuntu_Touch_AIDL_GSI
After=binder-bridge.service
Wants=binder-bridge.service
Before=ofono.service ModemManager.service

[Service]
Type=simple
ExecStart=/usr/lib/ubuntu-gsi/aidl/telephony/telephony_hal.sh
Restart=on-failure
RestartSec=5
TimeoutStartSec=90

# Security hardening
ProtectSystem=strict
ReadWritePaths=/data /run/ubuntu-gsi /tmp /etc/ofono /etc/ModemManager /etc/NetworkManager /dev/socket
NoNewPrivileges=false
PrivateTmp=no

# Modem device access
SupplementaryGroups=dialout

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=telephony-hal

[Install]
WantedBy=multi-user.target

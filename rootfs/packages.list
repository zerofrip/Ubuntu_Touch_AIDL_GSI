# =============================================================================
# rootfs/packages.list — Ubuntu GSI Required Packages
# =============================================================================
# One package per line. Lines starting with # are comments.
# These packages are installed into the rootfs during build.
# =============================================================================

# Core system
systemd
systemd-sysv
dbus
udev
sudo
bash
bash-completion
locales
ca-certificates

# Networking
network-manager
iproute2
iw
wpasupplicant
openssh-server
crda
wireless-regdb
rfkill

# Telephony / Modem
ofono
ofono-scripts
modemmanager
libqmi-utils
libmbim-utils
usb-modeswitch
usb-modeswitch-data

# Input / Touchscreen
libinput10
libinput-bin
libinput-tools
libevdev2
libmtdev1
evtest

# Binder / IPC support
libbinder-dev

# Audio
pulseaudio
pulseaudio-utils
alsa-utils
alsa-base
libasound2
libasound2-plugins

# Sensors
iio-sensor-proxy

# Camera
libcamera0.3
libcamera-tools
libcamera-ipa
gstreamer1.0-libcamera
gstreamer1.0-plugins-base
gstreamer1.0-plugins-good
v4l-utils
megapixels

# Power
upower

# Utilities
jq
curl

# GUI / Display
mir-graphics-drivers-desktop
mir-platform-graphics-wayland
libdrm2
libdrm-common
libgbm1
libegl1-mesa
libgles2-mesa
libgl1-mesa-dri
mesa-utils
libwayland-client0
libwayland-server0
lomiri
lomiri-system-settings
lomiri-indicator-network
lomiri-indicator-datetime
lomiri-indicator-session
lomiri-indicator-power

# On-screen keyboard & setup wizard
onboard
zenity
fonts-ubuntu
fonts-noto
adwaita-icon-theme
dbus-x11
nano
less
htop
e2fsprogs

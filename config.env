# =============================================================================
# config.env — Ubuntu GSI build configuration (AIDL variant)
# =============================================================================

# PHH Treble GSI base (AIDL repo defaults to Android 14 era)
PHH_GSI_VERSION=v559
PHH_GSI_VARIANT=arm64-ab-vanilla
# PHH_GSI_URL=https://github.com/phhusson/treble_experimentations/releases/download/v559/system-arm64-ab-vanilla.img.xz
# PHH_GSI_LOCAL=/absolute/path/to/phh-gsi.img

# Ubuntu chroot rootfs settings
ARCH=arm64
UBUNTU_SUITE=focal
UBUNTU_MIRROR=http://ports.ubuntu.com/ubuntu-ports

# EROFS compression (adjust if your kernel only supports plain lz4)
EROFS_COMP=lz4hc,9

# system.img size in MB (0 = auto content + headroom)
SYSTEM_IMG_SIZE_MB=0
